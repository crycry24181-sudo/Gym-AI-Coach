# Bỏ qua thư mục môi trường ảo (Nặng và không cần thiết)
.venv/
venv/
env/

# Bỏ qua file database (Nếu dùng SQLite)
db.sqlite3
*.sqlite3

# Bỏ qua các file rác của Python
__pycache__/
*.py[cod]

# Bỏ qua file cấu hình riêng tư (BẢO MẬT TUYỆT ĐỐI KHÔNG ĐƯỢC LÊN GITHUB)
.env

# Bỏ qua thư mục chứa file tĩnh do server tự build (Render sẽ tự tạo)
staticfiles/

# --- LỰA CHỌN VỀ ẢNH (MEDIA) ---
# Triển khai dự án thật (production) thì NÊN bỏ qua media để nhẹ repo.
media/
/media/